# Copy this file to .env and fill in values before running.
# Never commit .env to version control.

# PostgreSQL connection
PH_FX_POSTGRES_DSN=postgresql://fx:fx@localhost:5432/ph_fx
PH_FX_PG_HOST=postgres
PH_FX_PG_PORT=5432
PH_FX_PG_USER=fx
PH_FX_PG_PASSWORD=fx
PH_FX_PG_DBNAME=ph_fx

# Pipeline behaviour
PH_FX_START_YEAR=2017
PH_FX_MAX_RETRIES=3
PH_FX_REQUEST_TIMEOUT=30

# Alert threshold — fires when daily USD/PHP move exceeds this %
PH_FX_ALERT_THRESHOLD_PCT=1.5

# Ports
STREAMLIT_PORT=8501
ADMINER_PORT=8080
